{
  "name": "interview-prep-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,green\" \"pnpm --filter @workspace/api-server run dev\" \"pnpm --filter @workspace/interview-prep run dev\"",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:migrate:auth": "pnpm --filter @workspace/db run migrate:auth",
    "db:generate": "pnpm --filter @workspace/db run generate",
    "codegen": "pnpm --filter @workspace/api-spec run codegen"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
