{
  "name": "@workspace/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./schema": "./src/schema.js",
    "./client": "./src/client.js"
  },
  "scripts": {
    "generate": "drizzle-kit generate --config drizzle.config.cjs",
